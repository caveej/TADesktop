{
  "name": "taelectron",
  "version": "2.0.0",
  "description": "TA Launchpad",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win msi",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.ta.launchpad",
    "productName": "TA Launchpad",
    "win": {
      "target": "msi",
      "icon": "icon.png"
    },
    "msi": {
      "oneClick": false,
      "perMachine": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "files": [
      "main.js",
      "icon.png",
      "package.json"
    ]
  }
}
